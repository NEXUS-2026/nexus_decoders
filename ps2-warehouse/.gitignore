# --- Storage / Uploads ---
# Ignore everything in the storage directories, except .gitkeep files
# storage/videos/*
# !storage/videos/.gitkeep

# storage/challans/*
# !storage/challans/.gitkeep

# storage/uploads/*
# !storage/uploads/.gitkeep

# Other media/storage folders
# storage/temp/
# storage/logs/

